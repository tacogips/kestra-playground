#!/usr/bin/env bash
set -euo pipefail

mkdir -p /opt/kestra/config /tmp/kestra-wd

metadata() {
  curl -fsS -H "Metadata-Flavor: Google" "http://metadata.google.internal/computeMetadata/v1/$1"
}

access_token() {
  metadata "instance/service-accounts/default/token" |
    sed -n 's/.*"access_token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
}

read_secret() {
  local token
  token="$(access_token)"
  curl -fsS \
    -H "Authorization: Bearer $${token}" \
    "https://secretmanager.googleapis.com/v1/projects/${project_id}/secrets/${name_prefix}-gce-worker-$1/versions/latest:access" |
    tr -d '\n' |
    sed -n 's/.*"data"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' |
    base64 -d
}

KESTRA_DB_URL="$(read_secret kestra-db-url)"
KESTRA_DB_USERNAME="$(read_secret kestra-db-username)"
KESTRA_DB_PASSWORD="$(read_secret kestra-db-password)"
KESTRA_BASIC_AUTH_USERNAME="$(read_secret kestra-basic-auth-username)"
KESTRA_BASIC_AUTH_PASSWORD="$(read_secret kestra-basic-auth-password)"
ENV_BATCH_DB_URL="$(read_secret batch-db-url)"
ENV_BATCH_DB_USERNAME="$(read_secret batch-db-username)"
ENV_BATCH_DB_PASSWORD="$(read_secret batch-db-password)"
CLOUD_SQL_INSTANCE="$(read_secret cloud-sql-instance)"
KESTRA_GCS_BUCKET="$(read_secret kestra-gcs-bucket)"
TOKEN="$(access_token)"

printf '%s' "$${TOKEN}" | docker login -u oauth2accesstoken --password-stdin "https://${artifact_registry_host}"
docker network create kestra >/dev/null 2>&1 || true

cat >/opt/kestra/config/application.yaml <<'YAML'
datasources:
  postgres:
    url: $${KESTRA_DB_URL}
    driver-class-name: org.postgresql.Driver
    username: $${KESTRA_DB_USERNAME}
    password: $${KESTRA_DB_PASSWORD}
    maximum-pool-size: $${KESTRA_DB_MAX_POOL_SIZE:2}
kestra:
  server:
    basic-auth:
      username: $${KESTRA_BASIC_AUTH_USERNAME}
      password: $${KESTRA_BASIC_AUTH_PASSWORD}
  repository:
    type: postgres
  queue:
    type: postgres
  storage:
    type: gcs
    gcs:
      bucket: $${KESTRA_GCS_BUCKET}
  tasks:
    tmp-dir:
      path: /tmp/kestra-wd/tmp
  url: $${KESTRA_URL}
  variables:
    env-vars-prefix: "ENV_"
YAML

cat >/opt/kestra/.env <<EOF
KESTRA_DB_URL=$${KESTRA_DB_URL}
KESTRA_DB_USERNAME=$${KESTRA_DB_USERNAME}
KESTRA_DB_PASSWORD=$${KESTRA_DB_PASSWORD}
KESTRA_DB_MAX_POOL_SIZE=2
KESTRA_BASIC_AUTH_USERNAME=$${KESTRA_BASIC_AUTH_USERNAME}
KESTRA_BASIC_AUTH_PASSWORD=$${KESTRA_BASIC_AUTH_PASSWORD}
KESTRA_GCS_BUCKET=$${KESTRA_GCS_BUCKET}
KESTRA_URL=${kestra_url}
ENV_BATCH_DB_URL=$${ENV_BATCH_DB_URL}
ENV_BATCH_DB_USERNAME=$${ENV_BATCH_DB_USERNAME}
ENV_BATCH_DB_PASSWORD=$${ENV_BATCH_DB_PASSWORD}
CLOUD_SQL_INSTANCE=$${CLOUD_SQL_INSTANCE}
KESTRA_IMAGE=${kestra_image}
KESTRA_WORKER_GROUP_ARG=--worker-group=${worker_group_key}
KESTRA_WORKER_THREADS=${worker_threads}
EOF

docker rm -f cloud-sql-proxy kestra-worker >/dev/null 2>&1 || true
docker run -d \
  --name cloud-sql-proxy \
  --network kestra \
  --restart unless-stopped \
  gcr.io/cloud-sql-connectors/cloud-sql-proxy:2.14.1 \
  --structured-logs \
  --private-ip \
  --address=0.0.0.0 \
  --port=5432 \
  "$${CLOUD_SQL_INSTANCE}"

docker run -d \
  --name kestra-worker \
  --network kestra \
  --user root \
  --restart unless-stopped \
  --env-file /opt/kestra/.env \
  -v /tmp/kestra-wd:/tmp/kestra-wd \
  -v /opt/kestra/config/application.yaml:/etc/kestra/application.yaml:ro \
  "$${KESTRA_IMAGE}" \
  server worker --thread="$${KESTRA_WORKER_THREADS}" "$${KESTRA_WORKER_GROUP_ARG}" --config /etc/kestra/application.yaml
